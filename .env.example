# --- Application (non-secret) ---
# deploy.sh : seules les lignes « NOM_VARIABLE=valeur » sont chargées. Pas de titres seuls (ex. « Reseau: ») — utilisez « # Reseau ».
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=JD-Core

# --- UniFi (exemples fictifs — remplacer par vos vraies valeurs dans .env local) ---
# Priorité : UNIFI_* ; sinon les anciens noms UNIFI_CONTROLLER_HOST / UNIFI_USERNAME / UNIFI_PASSWORD.
UNIFI_IP=192.0.2.10
UNIFI_PORT=8443
UNIFI_USER=ubnt-admin-fake
UNIFI_PASS=not-a-real-password
UNIFI_SITE_NAME=default
UNIFI_CONTROLLER_HOST=192.0.2.10
UNIFI_USERNAME=ubnt-admin-fake
UNIFI_PASSWORD=not-a-real-password
UNIFI_API_TOKEN=uft_00000000000000000000000000000000

# --- Accès serveurs / SSH (exemples fictifs) ---
SSH_HOST_PRIMARY=198.51.100.22
SSH_PORT_PRIMARY=22
SSH_USER_PRIMARY=deploy
# Chemin vers une clé sur l'hôte (hors dépôt Git) ou secret Docker
SSH_PRIVATE_KEY_PATH=/run/secrets/deploy_key

# --- Tokens & secrets API ---
API_SECRET_TOKEN=sk_test_0123456789abcdef0123456789abcdef
WEBHOOK_SIGNING_SECRET=whsec_0123456789abcdef0123456789abcdef

# --- Statut HTTP des services (URLs interrogées par le serveur JD-Core, pas le navigateur) ---
# Exemples fictifs — utiliser vos URLs réelles (health, /status.php, /alive, etc.).
SERVICECHECK_NEXTCLOUD_URL=https://cloud.example.com/status.php
SERVICECHECK_VAULTWARDEN_URL=https://vault.example.com/alive
SERVICECHECK_UNRAID_URL=https://unraid.example.com/
# Délai max (ms) pour les pings HTTP des services et le scrape Prometheus Unraid (défaut 45000, min 5000, max 120000).
SERVICECHECK_FETCH_TIMEOUT_MS=45000

# --- Unraid : métriques Prometheus (widget avancé, optionnel) ---
# URL complète du endpoint /metrics (ex. node_exporter sur l’hôte Unraid, ou plugin dédié). Pas de SSH dans cette version.
# UNRAID_PROMETHEUS_URL=http://192.0.2.20:9100/metrics
# Point de montage pour le calcul d’usage disque (node_exporter : node_filesystem_*).
# UNRAID_POOL_MOUNTPOINT=/mnt/user
# JD-Core lit NOTES_DIR en priorité, sinon NOTES_PATH (ex. ./notes).
NOTES_DIR=/app/notes
# NOTES_PATH=./notes

# --- Montage NAS (optionnel — deploy.sh sur un hôte qui monte un partage avant Docker) ---
# Si NAS_MOUNT_SOURCE est absent ou vide, l’étape [3/6] est ignorée (test local : notes via ./notes dans docker-compose.yml).
# NAS_MOUNT_POINT=/mnt/nas_notes
# NAS_MOUNT_SOURCE=//192.0.2.10/NotesPartage
# NAS_FS_TYPE=cifs
# NAS_MOUNT_OPTIONS=credentials=/root/.smbcredentials,uid=1000,gid=1000,file_mode=0770,dir_mode=0770
