# --- Application (non-secret) ---
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=JD-Core

# --- UniFi (exemples fictifs — remplacer par vos vraies valeurs dans .env local) ---
# Priorité : UNIFI_* ; sinon les anciens noms UNIFI_CONTROLLER_HOST / UNIFI_USERNAME / UNIFI_PASSWORD.
UNIFI_IP=192.0.2.10
UNIFI_PORT=8443
UNIFI_USER=ubnt-admin-fake
UNIFI_PASS=not-a-real-password
UNIFI_SITE_NAME=default
UNIFI_CONTROLLER_HOST=192.0.2.10
UNIFI_USERNAME=ubnt-admin-fake
UNIFI_PASSWORD=not-a-real-password
UNIFI_API_TOKEN=uft_00000000000000000000000000000000

# --- Accès serveurs / SSH (exemples fictifs) ---
SSH_HOST_PRIMARY=198.51.100.22
SSH_PORT_PRIMARY=22
SSH_USER_PRIMARY=deploy
# Chemin vers une clé sur l'hôte (hors dépôt Git) ou secret Docker
SSH_PRIVATE_KEY_PATH=/run/secrets/deploy_key

# --- Tokens & secrets API ---
API_SECRET_TOKEN=sk_test_0123456789abcdef0123456789abcdef
WEBHOOK_SIGNING_SECRET=whsec_0123456789abcdef0123456789abcdef

# --- Statut HTTP des services (URLs interrogées par le serveur JD-Core, pas le navigateur) ---
# Exemples fictifs — utiliser vos URLs réelles (health, /status.php, /alive, etc.).
SERVICECHECK_NEXTCLOUD_URL=https://cloud.example.com/status.php
SERVICECHECK_VAULTWARDEN_URL=https://vault.example.com/alive
SERVICECHECK_UNRAID_URL=https://unraid.example.com/
